      "versionNonce": 1005450691,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1781144764150,
      "link": null,
      "locked": false,
      "text": "*To list files and directories on list format in the current location:\n\nls -la\n\n**We can add \"h\" for human readable format:\n\nls -lah",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "*To list files and directories on list format in the current location:\n\nls -la\n\n**We can add \"h\" for human readable format:\n\nls -lah",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9N4owKiHgigcvDQlYWLPc",
      "type": "text",
      "x": -4603.925148977756,
      "y": 1017.4123746148724,
