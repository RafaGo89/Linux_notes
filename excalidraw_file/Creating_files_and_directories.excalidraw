      "isDeleted": true,
      "boundElements": [],
      "updated": 1781144764150,
      "link": null,
      "locked": false,
      "text": "*To list ALL files and directories on the current location:\n\nls -a",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "*To list ALL files and directories on the current location:\n\nls -a",
      "autoResize": true,
      "lineHeight": 1.25
    },
