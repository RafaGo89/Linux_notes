      "type": "text",
      "x": -4606.356226973832,
      "y": 446.39009907378056,
      "width": 1714.930419921875,
      "height": 457.7337360959411,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
