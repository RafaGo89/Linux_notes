      "boundElements": [],
      "updated": 1780716016863,
      "link": null,
      "locked": false,
      "text": "To get to a file or directory path,\nwe can specify the route starting from\nthe root and then all subdirectories:\n\n/home/rafa/Documents/document.pdf",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To get to a file or directory path,\nwe can specify the route starting from\nthe root and then all subdirectories:\n\n/home/rafa/Documents/document.pdf",
      "autoResize": true,
      "lineHeight": 1.25
    },
