      "seed": 1120184356,
      "version": 321,
      "versionNonce": 2020191900,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780715176533,
      "link": null,
      "locked": false,
      "text": "*To list files and directories on list format in the current location:\n\nls -la\n\n**We can add \"h\" for human readable format:\n\nls -lah",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "*To list files and directories on list format in the current location:\n\nls -la\n\n**We can add \"h\" for human readable format:\n\nls -lah",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9N4owKiHgigcvDQlYWLPc",
      "type": "text",
      "x": -4603.925148977756,
      "y": 1017.4123746148724,
      "width": 1470.4337158203125,
      "height": 196.17160118397476,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 1147865508,
      "version": 271,
      "versionNonce": 1660956452,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780715168957,
      "link": null,
      "locked": false,
      "text": "*To list ALL files and directories on the current location:\n\nls -a",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "*To list ALL files and directories on the current location:\n\nls -a",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Z4dnKnjd0q2EcHw-HREMO",
      "type": "text",
