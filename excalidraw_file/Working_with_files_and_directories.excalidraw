      "isDeleted": false,
      "boundElements": [],
      "updated": 1780715635146,
      "link": null,
      "locked": false,
      "text": "On linux, files are organized like en inverted tree,\nstarting with the root / at the top and all\nsubsequent subdirectories below.",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On linux, files are organized like en inverted tree,\nstarting with the root / at the top and all\nsubsequent subdirectories below.",
      "autoResize": true,
      "lineHeight": 1.25
    },
