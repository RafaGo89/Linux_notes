      "isDeleted": false,
      "boundElements": [],
      "updated": 1780714971036,
      "link": null,
      "locked": false,
      "text": "*To list files and directories of a specific path:\n\nls /var/log",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "*To list files and directories of a specific path:\n\nls /var/log",
