      "boundElements": [],
      "updated": 1780716031586,
      "link": null,
      "locked": false,
      "text": "To get to a file or directory path,\nwe can specify the route starting from\nour current working directory:\n\nDocuments/document.pdf\n\n(assuming we are on /home/rafa/)",
      "fontSize": 52.31242698239326,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To get to a file or directory path,\nwe can specify the route starting from\nour current working directory:\n\nDocuments/document.pdf\n\n(assuming we are on /home/rafa/)",
      "autoResize": true,
      "lineHeight": 1.25
    },
